const { smd } = require("../lib");
const axios = require("axios");

smd({
    pattern: "draw",
    desc: "Génère une image à partir d'un texte",
    category: "ai",
    filename: __filename
}, async (message, text) => {
    // Vérification si un texte est fourni
    if (!text) return await message.reply("Veuillez décrire l'image (ex: .draw un astronaute sur Mars)");

    try {
        await message.reply("Veuillez patienter, Mr Anonymous, je génère votre image...");
        
        // Utilisation d'une API gratuite pour la génération (DALL-E alternative)
        const imageUrl = `https://api.popcat.xyz/dalle?prompt=${encodeURIComponent(text)}`;
        
        // Envoi de l'image générée
        await message.bot.sendFromUrl(message.jid, imageUrl, `Voici votre image générée.\nCréé par l'IA de Mr Anonymous.`, message);
    } catch (e) {
        console.error(e);
        await message.reply("Désolé, une erreur est survenue lors de la génération.");
    }
});
