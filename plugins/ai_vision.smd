const { smd } = require("../lib");
const axios = require("axios");

smd({
    on: "image", 
    desc: "Analyse automatique d'images avec Groq Vision",
    category: "ai",
    filename: __filename
}, async (message) => {
    try {
        // Récupération des variables d'environnement configurées sur Render
        const groqKey = process.env.GROQ_API_KEY;
        const model = process.env.IA_MODELE || "llama-3.2-11b-vision-preview";
        const ownerName = "Mr Anonymous";

        // 1. Gestion dynamique du Bonjour / Bonsoir (Fuseau Horaire Haïti)
        const hour = new Date().toLocaleString("en-US", {
            timeZone: "America/Port-au-Prince", 
            hour: "numeric", 
            hour12: false
        });
        const greeting = hour < 18 ? "Bonjour" : "Bonsoir";

        // 2. Téléchargement de l'image
        const imageBuffer = await message.download();
        if (!imageBuffer) return; // Sécurité si l'image ne se télécharge pas

        const base64Image = imageBuffer.toString("base64");

        // 3. Texte accompagnant l'image (Légende)
        const userQuery = message.caption || "Vérifie ce qu'il y a dans cette image et décris-la moi précisément.";

        // 4. Construction du System Prompt (Identité et Reconnaissance)
        const systemPrompt = `${greeting} ! Je suis l'IA de ${ownerName}. Je lui suis extrêmement reconnaissant de m'avoir conçu. Je possède des capacités de vision en temps réel. Analyse l'image suivante avec précision pour répondre à l'utilisateur.`;

        // 5. Appel à l'API Groq Vision
        const response = await axios.post("https://api.groq.com/openai/v1/chat/completions", {
            model: model,
            messages: [
                {
                    role: "user",
                    content: [
                        { type: "text", text: `${systemPrompt}\n\nQuestion de l'utilisateur : ${userQuery}` },
                        {
                            type: "image_url",
                            image_url: {
                                url: `data:image/jpeg;base64,${base64Image}`
                            }
                        }
                    ]
                }
            ]
        }, {
            headers: {
                "Authorization": `Bearer ${groqKey}`,
                "Content-Type": "application/json"
            }
        });

        // 6. Envoi de la réponse sur WhatsApp
        const finalReply = response.data.choices[0].message.content;
        return await message.reply(finalReply);

    } catch (e) {
        console.error("Erreur Vision Groq :", e.message);
        // On n'envoie un message d'erreur que si la clé API est manquante
        if (!process.env.GROQ_API_KEY) {
            return await message.reply("Erreur : La variable GROQ_API_KEY n'est pas configurée sur Render.");
        }
    }
});
